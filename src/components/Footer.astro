---
import { app } from "../firebase/server";
import { getFirestore } from "firebase-admin/firestore";
import AstroIcon from "../icons/AstroIcon.astro";
import type { About } from "../scripts/interface";

export interface Props {
  className?: string;
}

const db = getFirestore(app);
const aboutRef = db.collection("about");
const aboutSnapshot = await aboutRef.doc('PuZHqROjWYIeLSJuzVfc').get();
const about = aboutSnapshot.data() as About;

const { className } = Astro.props;
---

<footer data-cy="footer" class=`${className} mb-5 text-white bg-black dark:bg-transparent rounded-full`>
  <div class="inline-flex items-center space-x-3">
    <AstroIcon className="w-16 h-16 lg:h-[auto] lg:w-[auto]" />
    <p>Desarrollada con <a class="font-bold underline hover:text-purple-600" href="https://astro.build/" target="_blank">Astro</a></p>
  </div>
  <div data-cy="this-repository" class="inline-flex items-center space-x-3">
    <p>Échale un vistazo al <a class="font-bold underline hover:text-purple-600" href={about.thisApp.repository} target="_blank">código fuente</a></p>
  </div>
</footer>
---
import Layout from '../layouts/Layout.astro';
import About from '../components/About.astro';
import ProjectsData from '../components/ProjectsData.astro';
import Toast from '../components/Toast.astro';
import Warning from '../icons/Warning.astro';
import CheckIcon from '../icons/CheckIcon.astro';
---

<Layout title="Schweigender Flügel">
  <div class="flex justify-center">
	  <Toast keyword="error" className='mt-24 lg:mt-8 border border-red-700 dark:border-red-400 bg-red-200 dark:bg-transparent text-red-700 dark:text-red-400'>
	    <div class="flex items-center gap-x-3 text-[35px] lg:text-[16px]">
		    <Warning className='w-10 h-10 lg:w-5 lg:h-5'/>
		    <p>Se produjo un error al generar el documento</p>
	    </div>	
	  </Toast>
    <Toast keyword="discord-copied" className='mt-24 lg:mt-8 border border-green-700 dark:border-green-400 bg-green-200 dark:bg-transparent text-green-700 dark:text-green-400'>
      <div class="flex items-center gap-x-3 text-[35px] lg:text-[16px]">
        <CheckIcon className='w-10 h-10 lg:w-5 lg:h-5' />
        <p>Usuario de discord copiado</p>
      </div>	
    </Toast>
    <Toast keyword="discord-error" className='mt-24 lg:mt-8 border border-red-700 dark:border-red-400 bg-red-200 dark:bg-transparent text-red-700 dark:text-red-400'>
      <div class="flex items-center gap-x-3 text-[35px] lg:text-[16px]">
        <Warning className='w-10 h-10 lg:w-5 lg:h-5' />
        <p>Error al copiar usuario</p>
      </div>	
    </Toast>
  </div>
  <main class="sm:space-y-20 sm:py-20 lg:space-x-4">
    <section class="flex justify-center text-[40px] lg:text-[16px]">
      <About />
    </section>
    <section class="sm:flex sm:justify-center text-[40px] lg:text-[16px]">
      <ProjectsData />
    </section>
  </main>
</Layout>
